# Server
PORT=3002
PUBLIC_BASE_URL=https://your-domain.example
SQLITE_PATH=/opt/money-scissors/data/users.db

# Auth
AUTH_DISABLED=1

# Required only if AUTH_DISABLED=0
JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_EXPIRE_HOURS=168
ADMIN_PHONES=13800138000

# DashScope transcription
DASHSCOPE_API_KEY=replace-with-dashscope-key

# DeepSeek analysis
DEEPSEEK_KEY=replace-with-deepseek-key

# SMS verification. Required only if AUTH_DISABLED=0
ALIYUN_ACCESS_KEY_ID=replace-with-aliyun-ak-id
ALIYUN_ACCESS_KEY_SECRET=replace-with-aliyun-ak-secret
ALIYUN_SMS_SIGN=replace-with-sms-sign
ALIYUN_SMS_TEMPLATE=replace-with-sms-template-code

# Optional limits
MAX_JSON_BYTES=2097152
MAX_DAILY_SMS_PER_PHONE=5
MAX_SMS_SENDS_PER_IP_WINDOW=20
SMS_IP_WINDOW_MINUTES=10
MAX_VERIFY_ATTEMPTS=5
VERIFY_CODE_TTL_MINUTES=5
VERIFY_LOCK_MINUTES=30
REFINE_MAX_ACTIVE_JOBS=2
REFINE_MAX_ACTIVE_JOBS_PER_USER=1

# Development only. Do not enable on production.
ALLOW_DEV_SEND_CODE_FALLBACK=0
